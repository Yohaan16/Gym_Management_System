# Server Configuration
PORT=5001
NODE_ENV=development

# Database Configuration - replace with your values
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=gms_database
DB_CONNECTION_LIMIT=10

# Stripe Configuration - replace with your test/production keys
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Security Configuration
BCRYPT_ROUNDS=10
MIN_PASSWORD_LENGTH=6
# IMPORTANT: Replace with a secure random string (recommended >=32 chars)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=7d

# QR Token secret
QR_SECRET=your_qr_secret_here

# CORS Configuration
# Set to the origin you allow, e.g. http://localhost:3000 or https://yourdomain.com
CORS_ORIGIN=http://localhost:3000